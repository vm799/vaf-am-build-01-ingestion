# ── Core (required) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail Integration (optional) ─────────────────────────────
# Set ENABLE_GMAIL=true to activate email ingestion.
# Download credentials.json from Google Cloud Console first.
# See GMAIL_SETUP.md for step-by-step instructions.
ENABLE_GMAIL=false
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./gmail_token.json

# Gmail label to read: INBOX, UNREAD, or any custom label name.
# Tip: create a label "VAF-Ingestion" in Gmail and filter emails into it.
GMAIL_LABEL=INBOX
GMAIL_MAX_EMAILS=10

# ── File Share Watch (optional) ───────────────────────────────
# Set ENABLE_FILE_WATCH=true to ingest PDFs from a local folder.
# Drop PDF files into FILE_WATCH_DIR — pipeline picks them up automatically.
# Processed files are tracked; re-running won't duplicate them.
ENABLE_FILE_WATCH=false
FILE_WATCH_DIR=./data/file_watch

# Set to true to reprocess all files (clears seen-file state)
FILE_WATCH_RESET=false
